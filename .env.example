# Database
# PostgreSQL connection string used by Prisma (e.g. a Neon pooled connection string)
DATABASE_URL="postgresql://user:password@localhost:5432/hesabketab?schema=public"

# NextAuth (Auth.js v5)
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
# Optional: set to "true" when self-hosting behind a proxy (not needed on Vercel)
# AUTH_TRUST_HOST="true"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (Email)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Optional: from-address for outbound email (defaults to "HesabKetab <onboarding@resend.dev>")
# RESEND_FROM_EMAIL="HesabKetab <noreply@yourdomain.com>"
# Optional: where support-ticket emails are sent (defaults to the project owner's address)
# SUPPORT_EMAIL="support@yourdomain.com"
